# ── dFactory-Lab environment (copy to .env; never commit .env) ──────────────
# Server
DFACTORY_LAB_HOST=127.0.0.1
DFACTORY_LAB_PORT=8000
DFACTORY_LAB_TOKEN=            # bootstrap access token; auto-generated if empty
DFACTORY_LAB_DATA_DIR=./.lab   # managed dir for models, datasets, checkpoints, db

# Engine / training (mirrors train.sh defaults)
NNODES=1
NPROC_PER_NODE=                # defaults to GPU count
NODE_RANK=0
MASTER_ADDR=0.0.0.0
MASTER_PORT=12345
CUDA_DEVICE_ORDER=PCI_BUS_ID
TOKENIZERS_PARALLELISM=false
TORCH_NCCL_AVOID_RECORD_STREAMS=1

# Hugging Face
HF_TOKEN=

# Optional integrations
WANDB_PROJECT=
WANDB_NAME=
